# Copy this file to .env and fill in real values. Never commit .env itself.

ENV=development

# Comma-separated list is fine — app/utils/config.py will parse it
CORS_ORIGINS=["http://localhost:5173"]

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/plant_disease_db

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Path to your trained model file, relative to backend/
MODEL_PATH=model/model.pth
